# ─────────────────────────────────────────────────────────
# Blogton — Environment Variables
#
# These are NOT used directly by the browser.
# They are read server-side by netlify/functions/config.js
# and served to the client at runtime via /.netlify/functions/config
#
# For local dev: install Netlify CLI and run `netlify dev`
# ─────────────────────────────────────────────────────────

SUPABASE_URL;
SUPABASE_ANON_KEY;